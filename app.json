{
  "expo": {
    "name": "Zolva",
    "slug": "zolva-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "zolva",
    "splash": {
      "backgroundColor": "#EBE3D7"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "io.zolva.app",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Zolva sender notifikationer om påmindelser, dagens overblik og kommende møder.",
        "ITSAppUsesNonExemptEncryption": false,
        "SupabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNqa2hma2F0bWVxdHNyeXNpeG9wIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyNDA0MjMsImV4cCI6MjA5MTgxNjQyM30.pKadjlb7pQPXoZHfws4BvkdjyT2_hUeDtMFzX9v5_dY"
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.io.zolva.app"
        ],
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)io.zolva.shared"
        ]
      },
      "buildNumber": "17"
    },
    "android": {
      "package": "com.zolva.app",
      "versionCode": 1,
      "allowBackup": false,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android/adaptive-icon-foreground.png",
        "backgroundColor": "#0F4C2A"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "zolva"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-video",
      [
        "expo-notifications",
        {
          "icon": "./assets/android/notification-icon.png",
          "color": "#5C7355"
        }
      ],
      [
        "@bacons/apple-targets",
        {
          "appleTeamId": "N6WPH3FPFA"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ],
      "./plugins/widget-bridge/withWidgetBridge",
      "./plugins/voice-intents/withVoiceIntents"
    ],
    "extra": {
      "eas": {
        "projectId": "e66ee3ef-8891-477c-aff9-c5e7d6d3a828"
      },
      "privacyPolicyUrl": "https://albertfeldt1.github.io/ZolvaApp/"
    },
    "owner": "albertfeldt1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e66ee3ef-8891-477c-aff9-c5e7d6d3a828"
    }
  }
}
