# Copy to .env and fill in. Only EXPO_PUBLIC_* is exposed to the app bundle.
# Never put server-side secrets here — the mobile bundle is extractable.

EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
EXPO_PUBLIC_STRIPE_PRICE_ID=""
EXPO_PUBLIC_STRIPE_PRICE_BASIC=""

EXPO_PUBLIC_API_BASE_URL="http://localhost:3000"

# Anthropic is now proxied through the Supabase `claude-proxy` Edge Function.
# Set ANTHROPIC_API_KEY in Supabase dashboard -> Project Settings -> Edge Functions -> Secrets.
# Never add an Anthropic key to this file or any EXPO_PUBLIC_* variable.

# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=""
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=""
# EXPO_PUBLIC_MICROSOFT_CLIENT_ID=""
